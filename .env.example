# PEA Dashboard — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs

SECRET_KEY=CHANGER-CETTE-CLE-SECRETE-EN-PRODUCTION
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=pea_db
DB_USER=pea_user
DB_PASSWORD=CHANGER_MOT_DE_PASSE
DB_HOST=localhost
DB_PORT=5432

# Redis (DB 1 si partagé avec geoclic)
REDIS_URL=redis://127.0.0.1:6379/1

# EODHD — https://eodhd.com/register
EODHD_API_KEY=
EODHD_QUOTA_JOUR=20

# Mistral AI — https://console.mistral.ai
MISTRAL_API_KEY=

# NewsAPI — https://newsapi.org
NEWSAPI_KEY=

# FMP — https://financialmodelingprep.com
FMP_API_KEY=

# Email
EMAIL_DESTINATAIRE=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard
DASHBOARD_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
