{
  "name": "pea-dashboard",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "lightweight-charts": "^4.1.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build"
  },
  "proxy": "http://localhost:8000",
  "browserslist": {
    "production": [">0.2%", "not dead"],
    "development": ["last 1 chrome version"]
  }
}

/*
===================================================================
STRUCTURE COMPLÈTE DU FRONTEND
===================================================================

frontend/
├── package.json                    ✅ (ce fichier)
├── public/
│   └── index.html
└── src/
    ├── index.js                    → point d'entrée React
    ├── App.jsx                     → routing principal
    ├── index.css                   → variables CSS globales
    ├── api/
    │   └── client.js               ✅ Fait
    ├── hooks/
    │   ├── useTitre.js             ✅ Fait
    │   └── useTitres.js            ✅ Fait (dans hooks.js)
    ├── pages/
    │   └── Dashboard.jsx           ✅ Fait
    └── components/
        ├── GraphiqueTechnique.jsx  ✅ Fait
        ├── FicheTitre.jsx          ✅ Fait
        ├── BadgeSentiment.jsx      ✅ Fait (dans utilitaires.jsx)
        ├── CarteSignaux.jsx        ✅ Fait (dans utilitaires.jsx)
        ├── FeedArticles.jsx        ✅ Fait (dans utilitaires.jsx)
        ├── CarteAlertes.jsx        ✅ Fait (dans utilitaires.jsx)
        ├── ListeSurveillance.jsx   ✅ Fait (dans utilitaires.jsx)
        ├── PanneauAlertes.jsx      ✅ Fait (dans utilitaires.jsx)
        └── QuotaBadge.jsx          ✅ Fait (dans utilitaires.jsx)

===================================================================
FICHIERS DE DÉMARRAGE (à créer manuellement)
===================================================================

--- src/index.js ---
import React from 'react'
import ReactDOM from 'react-dom/client'
import './index.css'
import App from './App'

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode><App /></React.StrictMode>
)

--- src/App.jsx ---
import React from 'react'
import Dashboard from './pages/Dashboard'
export default function App() { return <Dashboard /> }

--- src/index.css ---
:root {
  --color-background-primary:   #ffffff;
  --color-background-secondary: #f5f5f3;
  --color-background-tertiary:  #eeede8;
  --color-background-success:   #e1f5ee;
  --color-background-warning:   #faeeda;
  --color-background-danger:    #fcebeb;
  --color-background-info:      #e6f1fb;
  --color-text-primary:         #1a1a18;
  --color-text-secondary:       #5f5e5a;
  --color-text-tertiary:        #888780;
  --color-text-success:         #0f6e56;
  --color-text-warning:         #854f0b;
  --color-text-danger:          #a32d2d;
  --color-text-info:            #185fa5;
  --color-border-tertiary:      rgba(0,0,0,0.10);
  --color-border-secondary:     rgba(0,0,0,0.18);
  --color-border-success:       #5dcaa5;
  --color-border-warning:       #ef9f27;
  --color-border-danger:        #f09595;
  --color-border-info:          #85b7eb;
  --border-radius-md:           8px;
  --border-radius-lg:           12px;
  --border-radius-xl:           16px;
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-sans); font-size: 14px; color: var(--color-text-primary); background: var(--color-background-tertiary); }
button { font-family: inherit; }

@media (prefers-color-scheme: dark) {
  :root {
    --color-background-primary:   #1a1a18;
    --color-background-secondary: #242422;
    --color-background-tertiary:  #111110;
    --color-text-primary:         #e8e6dc;
    --color-text-secondary:       #a8a69c;
    --color-text-tertiary:        #6e6c66;
    --color-border-tertiary:      rgba(255,255,255,0.08);
    --color-border-secondary:     rgba(255,255,255,0.15);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}

===================================================================
INSTALLATION & DÉMARRAGE
===================================================================

cd frontend
npm install
npm start

L'app tourne sur http://localhost:3000
Le proxy redirige /api/* vers http://localhost:8000

===================================================================
BUILD PRODUCTION (pour le VPS OVH)
===================================================================

npm run build
# Copier le dossier build/ dans /var/www/pea/
# Nginx sert les fichiers statiques depuis ce dossier
*/
